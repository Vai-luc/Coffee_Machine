# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Database (optional - uses JSON fallback if not set)
# PostgreSQL connection string for production
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port (default: 5000)
PORT=5000

# For local development, you can leave DATABASE_URL unset
# The app will automatically use JSON file storage in the data/ directory
